{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@founder-mobile/ui": ["packages/ui/src/index.tsx"],
      "@founder-mobile/db": ["packages/db/src/index.ts"],
      "@founder-mobile/db/*": ["packages/db/src/*"],
      "@/*": ["packages/ui/src/*"]
    }
  }
}
