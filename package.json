{
  "name": "founder-mobile",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra"
  ],
  "type": "module",
  "scripts": {
    "dev:web": "bun --cwd apps/web dev",
    "dev:mobile": "bun --cwd apps/mobile start",
    "dev:backend": "bun --cwd apps/backend dev",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "check": "bun run format:check && bun run lint && bun run typecheck",
    "typecheck": "tsgo -p packages/db && tsgo -p packages/auth && tsgo -p packages/ui && tsgo -p apps/backend && tsgo -p apps/web && tsgo -p apps/mobile --noEmit && tsgo -p infra",
    "build": "bun run typecheck",
    "prepare": "husky",
    "preview:deploy": "bun scripts/deploy-branch-preview.ts",
    "preview:destroy": "bun scripts/destroy-branch-preview.ts",
    "preview:info": "bun scripts/preview-info.ts",
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy",
    "db:generate": "bun --cwd packages/db drizzle-kit generate",
    "db:studio": "bun --cwd packages/db drizzle-kit studio"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@effect/platform-bun": "4.0.0-beta.93",
    "@effect/platform-node": "4.0.0-beta.93",
    "@types/bun": "latest",
    "@types/node": "^26.1.1",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "alchemy": "^2.0.0-beta.61",
    "effect": "4.0.0-beta.93",
    "husky": "latest",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "shadcn": "^4.13.0",
    "typescript": "7.0.2",
    "wrangler": "latest"
  }
}
